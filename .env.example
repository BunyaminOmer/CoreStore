# SECURITY
# Generate a real value for production. Do not reuse this placeholder.
SECRET_KEY=change-me-to-a-long-random-secret-key
DEBUG=False

# DOMAIN (GoDaddy domain without https://)
DOMAIN=siteniz.com

# Optional extra hosts/origins, comma-separated.
ALLOWED_HOSTS=
CSRF_TRUSTED_ORIGINS=

# DATABASE (Render PostgreSQL internal URL or another PostgreSQL URL)
# Example: postgresql://user:password@host:5432/database
DATABASE_URL=

# CLOUDINARY (required for uploaded product/category/avatar images in production)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
REQUIRE_CLOUDINARY=True

# HTTPS security. Keep HSTS modest for first launch; raise after the domain is stable.
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=3600
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
